# Copy this file to .env and fill in real values — never commit .env
#
# For local development (running backend directly with uvicorn):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/inventory_db
#
# For Docker Compose (the compose file auto-adds +psycopg, so standard URL is fine):
# DATABASE_URL=postgresql://postgres:yourpassword@db:5432/inventory_db
#
# Note: database.py auto-normalizes postgresql:// → postgresql+psycopg://
# so you can use either form here.

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
